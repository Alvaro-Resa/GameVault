<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/otp_title"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/otp_description"
        android:textColor="#CCCCCC"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/etOtpCode"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:drawable/edit_text"
        android:hint="@string/otp_hint_code"

        android:inputType="number"
        android:maxLength="6"

        android:textSize="24sp"
        android:letterSpacing="0.3"
        android:gravity="center"
        android:padding="10dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnVerifyOtp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/otp_btn_verify"
        android:backgroundTint="#FF4500" />

    <ProgressBar
        android:id="@+id/pbOtpLoading"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>