<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gv_background">

    <!-- Indicador de Carga -->
    <ProgressBar
        android:id="@+id/pbLibLoading"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:indeterminateTint="@color/gv_red_glow"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header -->
    <TextView
        android:id="@+id/lblHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:text="Your Library"
        android:textColor="@color/gv_red_glow"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tabs Juegos / Mangas -->
    <LinearLayout
        android:id="@+id/libTabRow"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/lblHeader"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/btnLibTabGames"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Games"
            android:textColor="@color/gv_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:background="@drawable/bg_red_line" />

        <TextView
            android:id="@+id/btnLibTabMangas"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Mangas"
            android:textColor="@color/gv_text_secondary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/libScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/libTabRow"
        app:layout_constraintBottom_toTopOf="@id/bottomNavLine">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp">
            
            <!-- Guest Banner -->
            <LinearLayout
                android:id="@+id/layoutGuestLibrary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginTop="60dp">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="@color/gv_text_secondary"
                    android:layout_marginBottom="16dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log in to view your library"
                    android:textColor="@color/gv_text_primary"
                    android:textSize="18sp"
                    android:layout_marginBottom="24dp" />
                <Button
                    android:id="@+id/btnLoginLibrary"
                    android:layout_width="200dp"
                    android:layout_height="60dp"
                    android:text="Log In"
                    android:backgroundTint="@color/gv_red_glow"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Authenticated Library View -->
            <LinearLayout
                android:id="@+id/layoutAuthLibrary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <!-- 4 Stats -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_search_bar"
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/txtLibGames"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gv_red_glow"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gv_text_secondary"
                            android:textSize="10sp"
                            android:text="Games" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_search_bar"
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/txtLibHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gv_red_glow"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gv_text_secondary"
                            android:textSize="10sp"
                            android:text="Total Hours" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_search_bar"
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/txtLibCompleted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gv_red_glow"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gv_text_secondary"
                            android:textSize="10sp"
                            android:text="Completed" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        android:background="@drawable/bg_search_bar"
                        android:padding="12dp"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/txtLibReviews"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gv_red_glow"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:text="0" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gv_text_secondary"
                            android:textSize="10sp"
                            android:text="Reviews" />
                    </LinearLayout>
                </GridLayout>
                
                <!-- Filters -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStatusFilter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvGenreFilter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="16dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <!-- Main Library List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvUserGames"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="16dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_game" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Line -->
    <View
        android:id="@+id/bottomNavLine"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/bg_red_line"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">
        <ImageView android:id="@+id/btnNavUserLib" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:src="@android:drawable/ic_menu_myplaces" app:tint="@color/gv_text_secondary" />
        <ImageView android:id="@+id/btnNavHomeLib" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:src="@android:drawable/ic_menu_search" app:tint="@color/gv_text_secondary" />
        <ImageView android:id="@+id/btnNavLibraryLib" android:layout_width="0dp" android:layout_height="30dp" android:layout_weight="1" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="@color/gv_red_glow" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>