<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gv_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- 1. Header Image Section -->
        <ImageView
            android:id="@+id/imgGameCover"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@android:color/darker_gray" />

        <View
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/bg_gradient_overlay"
            app:layout_constraintBottom_toBottomOf="@id/imgGameCover" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_rating_tag"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/gv_text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 2. Meta Info Section -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="-30dp"
            app:layout_constraintTop_toBottomOf="@id/imgGameCover">

            <TextView
                android:id="@+id/txtGameTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gv_text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                tools:text="The Last of Us" />

            <TextView
                android:id="@+id/txtReleaseYear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gv_text_hint"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                tools:text="2013" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/gv_red_glow" />

                <TextView
                    android:id="@+id/txtTopRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gv_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    tools:text="10.0/10" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  •  "
                    android:textColor="@color/gv_text_hint" />

                <TextView
                    android:id="@+id/txtReviewCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gv_text_hint"
                    android:textSize="14sp"
                    tools:text="1 reviews" />
            </LinearLayout>

            <Button
                android:id="@+id/btnAddToLibrary"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_marginTop="16dp"
                android:text="Status"
                android:paddingHorizontal="24dp"
                android:textColor="@color/gv_text_primary"
                android:backgroundTint="#4DFF0000"
                app:strokeColor="@color/gv_red_glow"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progress (Hours/Chapters)"
                android:textColor="@color/gv_text_hint"
                android:textSize="12sp"
                android:layout_marginTop="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etHoursPlayed"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_search_bar"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/gv_text_primary"
                    android:inputType="number"
                    tools:text="45" />

                <Button
                    android:id="@+id/btnSaveHours"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:text="Save"
                    android:backgroundTint="@color/gv_red_glow"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gv_red_glow"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp" />

            <!-- Meta Data Grid (CORREGIDO CON IDs) -->
            <TextView
                android:id="@+id/lblDeveloper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Developer"
                android:textColor="@color/gv_text_hint"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtDevName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gv_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                tools:text="Naughty Dog" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Release Date"
                android:textColor="@color/gv_text_hint"
                android:textSize="12sp"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/txtFullRelease"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gv_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                tools:text="June 14, 2013" />

            <TextView
                android:id="@+id/lblGenre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Genres"
                android:textColor="@color/gv_text_hint"
                android:textSize="12sp"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/txtGenresPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gv_text_primary"
                android:background="@drawable/bg_rating_tag"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="8dp"
                android:textSize="14sp"
                tools:text="Action-Adventure" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Synopsis"
                android:textColor="@color/gv_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp" />

            <TextView
                android:id="@+id/txtSynopsis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/gv_text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="16dp"
                tools:text="A description..." />

        </LinearLayout>

        <!-- Review form -->
        <LinearLayout
            android:id="@+id/containerWriteReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_search_bar"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/contentLayout">

            <LinearLayout
                android:id="@+id/layoutGuestReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You must log in to write a review"
                    android:textColor="@color/gv_text_primary"
                    android:layout_marginBottom="12dp" />
                <Button
                    android:id="@+id/btnLoginPrompt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log In"
                    android:backgroundTint="@color/gv_red_glow" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAuthReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Score:"
                        android:textColor="@color/gv_text_hint" />
                    <SeekBar
                        android:id="@+id/seekBarRating"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="@color/gv_red_glow"
                        android:thumbTint="@color/gv_red_glow" />
                    <TextView
                        android:id="@+id/txtRatingValue"
                        android:layout_width="35dp"
                        android:layout_height="wrap_content"
                        android:text="50"
                        android:textAlignment="viewEnd"
                        android:textColor="@color/gv_text_primary" />
                </LinearLayout>

                <EditText
                    android:id="@+id/etReviewTitle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Review Title"
                    android:textColor="@color/gv_text_primary"
                    android:textColorHint="@color/gv_text_hint"
                    android:background="@android:color/transparent" />

                <EditText
                    android:id="@+id/etReviewBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="3"
                    android:hint="Write your review here..."
                    android:textColor="@color/gv_text_primary"
                    android:textColorHint="@color/gv_text_hint"
                    android:background="@android:color/transparent"
                    android:inputType="textMultiLine"
                    android:gravity="top" />

                <Button
                    android:id="@+id/btnSubmitReview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Post Review"
                    android:backgroundTint="@color/gv_red_glow" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/lblReviewsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reviews"
            android:textColor="@color/gv_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/containerWriteReview" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="16dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/lblReviewsList" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>